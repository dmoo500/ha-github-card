{
  "name": "ha-github-card",
  "version": "1.0.0",
  "description": "Home Assistant custom Lovelace card to display GitHub service information",
  "main": "ha-github-card.js",
  "homepage": "https://github.com/your-username/ha-github-card",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/ha-github-card.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/ha-github-card/issues"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "serve": "python3 -m http.server 8000",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.js",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "yarn build",
    "release": "yarn type-check && yarn build"
  },
  "keywords": [
    "home-assistant",
    "hacs",
    "custom-card",
    "lovelace",
    "github",
    "typescript",
    "lit-element"
  ],
  "author": {
    "name": "ha-github-card Contributors"
  },
  "license": "MIT",
  "packageManager": "yarn@4.12.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "lit": "^3.0.0"
  }
}
