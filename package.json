{
  "name": "ha-github-card",
  "version": "1.0.0",
  "description": "Home Assistant custom Lovelace card to display GitHub service information",
  "main": "ha-github-card.js",
  "homepage": "https://github.com/your-username/ha-github-card",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/ha-github-card.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/ha-github-card/issues"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "serve": "python3 -m http.server 8000",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "yarn build",
    "release": "yarn type-check && yarn build"
  },
  "keywords": [
    "home-assistant",
    "hacs",
    "custom-card",
    "lovelace",
    "github",
    "typescript",
    "lit-element"
  ],
  "author": {
    "name": "ha-github-card Contributors"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "lit": "^3.0.0"
  }
}
